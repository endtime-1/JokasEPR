# Jokas ERP — Backup Configuration
# Copy this file to backup.env and fill in your values.
# Never commit backup.env to source control.

# =============================================================================
# DATABASE
# =============================================================================
# Full PostgreSQL connection string from your .env
DATABASE_URL="postgresql://jokas_user:CHANGE_ME@localhost:5432/jokas_erp"

# =============================================================================
# PATHS
# =============================================================================
# Root directory where all local backups are written
BACKUP_ROOT="/opt/jokas/backups"

# Directory where the API stores uploaded files (set UPLOAD_DIR in apps/api .env)
APP_UPLOAD_DIR="/opt/jokas/uploads"

# =============================================================================
# RETENTION (in days)
# =============================================================================
RETAIN_DAILY=7      # keep daily backups for 7 days
RETAIN_WEEKLY=30    # keep weekly backups for 30 days
RETAIN_MONTHLY=365  # keep monthly backups for 365 days

# =============================================================================
# CLOUD STORAGE (optional — leave blank to skip S3 upload)
# Requires: aws-cli installed and configured
# =============================================================================
S3_BUCKET=""
S3_PREFIX="jokas-erp-backups"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION="us-east-1"

# =============================================================================
# NOTIFICATIONS (optional)
# =============================================================================
# Slack incoming webhook URL — receive success/failure alerts
SLACK_WEBHOOK_URL=""

# Email address to notify on backup failure (requires mailutils/sendmail)
ALERT_EMAIL=""
