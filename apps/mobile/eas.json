{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.13.0"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.13.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://jokasfarms.com/api/v1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.13.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://jokasfarms.com/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
