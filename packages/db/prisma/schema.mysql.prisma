model StockMovement {
  id                   String            @id @default(uuid())
  companyId            String           
  branchId             String           
  productId            String           
  inventoryItemId      String?          
  stockBatchId         String?          
  fromWarehouseId      String?          
  toWarehouseId        String?          
  fromFarmId           String?          
  toFarmId             String?          
  fromProductionSiteId String?          
  toProductionSiteId   String?          
  farmId               String?          
  warehouseId          String?          
  productionSiteId     String?          
  uomId                String           
  movementType         StockMovementType
  quantity             Decimal           @db.Decimal(18, 4)
  unitCost             Decimal?          @db.Decimal(18, 4)
  referenceType        String?
  referenceId          String?
  notes                String?
  createdById          String?          
  updatedById          String?          
  movementDate         DateTime          @default(now())
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  deletedAt            DateTime?

  company            Company         @relation(fields: [companyId], references: [id])
  branch             Branch          @relation(fields: [branchId], references: [id])
  product            Product         @relation(fields: [productId], references: [id])
  inventoryItem      InventoryItem?  @relation(fields: [inventoryItemId], references: [id])
  stockBatch         StockBatch?     @relation(fields: [stockBatchId], references: [id])
  fromWarehouse      Warehouse?      @relation("StockMovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse        Warehouse?      @relation("StockMovementToWarehouse", fields: [toWarehouseId], references: [id])
  fromFarm           Farm?           @relation("StockMovementFromFarm", fields: [fromFarmId], references: [id])
  toFarm             Farm?           @relation("StockMovementToFarm", fields: [toFarmId], references: [id])
  fromProductionSite ProductionSite? @relation("StockMovementFromProductionSite", fields: [fromProductionSiteId], references: [id])
  toProductionSite   ProductionSite? @relation("StockMovementToProductionSite", fields: [toProductionSiteId], references: [id])
  farm               Farm?           @relation("StockMovementFarmContext", fields: [farmId], references: [id])
  warehouse          Warehouse?      @relation("StockMovementWarehouseContext", fields: [warehouseId], references: [id])
  productionSite     ProductionSite? @relation("StockMovementProductionSiteContext", fields: [productionSiteId], references: [id])
  uom                UnitOfMeasure   @relation(fields: [uomId], references: [id])
  createdBy          User?           @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([farmId])
  @@index([warehouseId])
  @@index([productionSiteId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([fromFarmId])
  @@index([toFarmId])
  @@index([fromProductionSiteId])
  @@index([toProductionSiteId])
  @@index([companyId, movementType])
  @@index([companyId, createdAt])
  @@index([movementDate])
  @@index([referenceType, referenceId])
  @@index([deletedAt])
}

