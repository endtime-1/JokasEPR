// ─── HR Module ────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  PUBLIC_HOLIDAY
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskAssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum TrainingOutcome {
  PASSED
  FAILED
  ONGOING
  CANCELLED
}

enum HRRating {
  OUTSTANDING
  EXCEEDS_EXPECTATIONS
  MEETS_EXPECTATIONS
  NEEDS_IMPROVEMENT
  UNSATISFACTORY
}

enum HRPerformanceStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  ACKNOWLEDGED
}

model EmployeeRole {
  id          String    @id @default(uuid())
  companyId   String   
  code        String    @db.VarChar(24)
  name        String    @db.VarChar(120)
  description String?   @db.VarChar(240)
  isActive    Boolean   @default(true)
  createdById String?  
  updatedById String?  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([deletedAt])
}

model Employee {
  id                    String         @id @default(uuid())
  companyId             String        
  code                  String         @db.VarChar(30)
  firstName             String         @db.VarChar(80)
  lastName              String         @db.VarChar(80)
  fullName              String         @db.VarChar(160)
  dateOfBirth           DateTime?
  gender                Gender?
  phone                 String?        @db.VarChar(40)
  email                 String?        @db.VarChar(160)
  address               String?        @db.VarChar(300)
  nationalId            String?        @db.VarChar(40)
  startDate             DateTime
  endDate               DateTime?
  status                EmployeeStatus @default(ACTIVE)
  employeeRoleId        String?       
  branchId              String?       
  farmId                String?       
  warehouseId           String?       
  productionSiteId      String?       
  basicSalary           Decimal?       @db.Decimal(15, 2)
  bankName              String?        @db.VarChar(120)
  bankAccount           String?        @db.VarChar(40)
  ssnitNumber           String?        @db.VarChar(20)
  tinNumber             String?        @db.VarChar(20)
  emergencyContactName  String?        @db.VarChar(120)
  emergencyContactPhone String?        @db.VarChar(40)
  notes                 String?        @db.VarChar(500)
  createdById           String?       
  updatedById           String?       
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  deletedAt             DateTime?

  company              Company              @relation(fields: [companyId], references: [id])
  employeeRole         EmployeeRole?        @relation(fields: [employeeRoleId], references: [id])
  branch               Branch?              @relation(fields: [branchId], references: [id])
  farm                 Farm?                @relation(fields: [farmId], references: [id])
  warehouse            Warehouse?           @relation(fields: [warehouseId], references: [id])
  productionSite       ProductionSite?      @relation(fields: [productionSiteId], references: [id])
  attendanceRecords     AttendanceRecord[]
  taskAssignments       TaskAssignment[]
  payrollRecords        PayrollRecord[]
  trainingRecords       TrainingRecord[]
  performanceRecords    HRPerformanceRecord[]
  departmentAssignments DepartmentAssignment[]
  leaveRequests         LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, employeeRoleId])
  @@index([branchId])
  @@index([farmId])
  @@index([warehouseId])
  @@index([productionSiteId])
  @@index([deletedAt])
}

model AttendanceRecord {
  id           String           @id @default(uuid())
  companyId    String          
  employeeId   String          
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus @default(PRESENT)
  hoursWorked  Decimal?         @db.Decimal(5, 2)
  shiftId      String?         
  notes        String?          @db.VarChar(240)
  recordedById String?         
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company    Company   @relation(fields: [companyId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  shift      Shift?    @relation(fields: [shiftId], references: [id])
  recordedBy User?     @relation("AttendanceRecorder", fields: [recordedById], references: [id])

  @@unique([companyId, employeeId, date])
  @@index([companyId])
  @@index([companyId, date])
  @@index([employeeId])
  @@index([companyId, status])
}

model Shift {
  id          String    @id @default(uuid())
  companyId   String   
  branchId    String?  
  code        String    @db.VarChar(24)
  name        String    @db.VarChar(120)
  startTime   String    @db.VarChar(5)
  endTime     String    @db.VarChar(5)
  isActive    Boolean   @default(true)
  notes       String?   @db.VarChar(240)
  createdById String?  
  updatedById String?  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company           Company            @relation(fields: [companyId], references: [id])
  branch            Branch?            @relation(fields: [branchId], references: [id])
  attendanceRecords AttendanceRecord[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([deletedAt])
}

model Task {
  id               String       @id @default(uuid())
  companyId        String      
  title            String       @db.VarChar(200)
  description      String?      @db.VarChar(1000)
  taskType         String?      @db.VarChar(60)
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(OPEN)
  dueDate          DateTime?
  completedAt      DateTime?
  branchId         String?     
  farmId           String?     
  productionSiteId String?     
  assignedById     String?     
  notes            String?      @db.VarChar(500)
  createdById      String?     
  updatedById      String?     
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  company        Company          @relation(fields: [companyId], references: [id])
  branch         Branch?          @relation(fields: [branchId], references: [id])
  farm           Farm?            @relation(fields: [farmId], references: [id])
  productionSite ProductionSite?  @relation(fields: [productionSiteId], references: [id])
  assignedBy     User?            @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignments    TaskAssignment[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, priority])
  @@index([companyId, dueDate])
  @@index([branchId])
  @@index([deletedAt])
}

model TaskAssignment {
  id          String               @id @default(uuid())
  companyId   String              
  taskId      String              
  employeeId  String              
  assignedById String?            
  status      TaskAssignmentStatus @default(ASSIGNED)
  completedAt DateTime?
  notes       String?              @db.VarChar(500)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  company    Company   @relation(fields: [companyId], references: [id])
  task       Task      @relation(fields: [taskId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  assignedBy User?     @relation("TaskAssignmentAssigner", fields: [assignedById], references: [id])

  @@unique([taskId, employeeId])
  @@index([companyId])
  @@index([taskId])
  @@index([employeeId])
  @@index([companyId, status])
}

model TrainingRecord {
  id            String          @id @default(uuid())
  companyId     String         
  employeeId    String         
  title         String          @db.VarChar(200)
  description   String?         @db.VarChar(500)
  trainer       String?         @db.VarChar(120)
  trainingDate  DateTime
  durationHours Decimal?        @db.Decimal(5, 1)
  outcome       TrainingOutcome @default(ONGOING)
  certificate   String?         @db.VarChar(120)
  notes         String?         @db.VarChar(500)
  createdById   String?        
  updatedById   String?        
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, trainingDate])
  @@index([deletedAt])
}

model HRPerformanceRecord {
  id                  String              @id @default(uuid())
  companyId           String             
  employeeId          String             
  period              String              @db.VarChar(10)
  reviewerId          String?            
  overallRating       HRRating            @default(MEETS_EXPECTATIONS)
  attendanceScore     Int                 @default(0)
  taskCompletionScore Int                 @default(0)
  qualityScore        Int                 @default(0)
  teamworkScore       Int                 @default(0)
  comments            String?             @db.VarChar(1000)
  goals               String?             @db.VarChar(500)
  status              HRPerformanceStatus @default(DRAFT)
  acknowledgedAt      DateTime?
  createdById         String?            
  updatedById         String?            
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
  reviewer User?    @relation("PerformanceReviewer", fields: [reviewerId], references: [id])

  @@unique([companyId, employeeId, period])
  @@index([companyId])
  @@index([employeeId])
  @@index([companyId, period])
  @@index([companyId, status])
  @@index([deletedAt])
}

model DepartmentAssignment {
  id               String    @id @default(uuid())
  companyId        String   
  employeeId       String   
  branchId         String?  
  farmId           String?  
  warehouseId      String?  
  productionSiteId String?  
  department       String    @db.VarChar(120)
  startDate        DateTime
  endDate          DateTime?
  isPrimary        Boolean   @default(true)
  notes            String?   @db.VarChar(240)
  createdById      String?  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company        Company        @relation(fields: [companyId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])
  branch         Branch?        @relation(fields: [branchId], references: [id])
  farm           Farm?          @relation(fields: [farmId], references: [id])
  warehouse      Warehouse?     @relation(fields: [warehouseId], references: [id])
  productionSite ProductionSite? @relation(fields: [productionSiteId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([branchId])
  @@index([farmId])
  @@index([warehouseId])
  @@index([productionSiteId])
  @@index([companyId, startDate])
}

// ─── Quality Control ─────────────────────────────────────────────────────────

enum QCCheckType {
  RAW_MATERIAL
  FEED_PRODUCTION
  SOYA_PROCESSING
  FINISHED_GOODS
  POULTRY_HEALTH
  GOODS_RECEIVED
}

enum QCStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  CONDITIONALLY_PASSED
  CANCELLED
}

enum QCParameterType {
  NUMERIC
  BOOLEAN
  TEXT
  PERCENTAGE
}

enum BatchDecision {
  PENDING
  APPROVED
  REJECTED
  QUARANTINE
  CONDITIONALLY_APPROVED
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum DisposalMethod {
  RETURN_TO_SUPPLIER
  DESTROY
  DOWNGRADE
  REWORK
  QUARANTINE
}

model QualityCheckTemplate {
  id          String      @id @default(uuid())
  companyId   String     
  code        String      @db.VarChar(30)
  name        String      @db.VarChar(160)
  checkType   QCCheckType
  description String?     @db.VarChar(500)
  isActive    Boolean     @default(true)
  createdById String?    
  updatedById String?    
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  company    Company                 @relation(fields: [companyId], references: [id])
  parameters QualityCheckParameter[]
  checks     QualityCheck[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, checkType])
  @@index([deletedAt])
}

model QualityCheckParameter {
  id            String          @id @default(uuid())
  companyId     String         
  templateId    String         
  paramCode     String          @db.VarChar(30)
  name          String          @db.VarChar(120)
  paramType     QCParameterType @default(NUMERIC)
  unit          String?         @db.VarChar(30)
  minValue      Decimal?        @db.Decimal(12, 4)
  maxValue      Decimal?        @db.Decimal(12, 4)
  expectedValue String?         @db.VarChar(120)
  isRequired    Boolean         @default(true)
  sortOrder     Int             @default(0)
  notes         String?         @db.VarChar(240)
  createdById   String?        
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company   Company              @relation(fields: [companyId], references: [id])
  template  QualityCheckTemplate @relation(fields: [templateId], references: [id])
  results   QualityInspectionResult[]

  @@unique([templateId, paramCode])
  @@index([companyId])
  @@index([templateId])
}

model QualityCheck {
  id               String        @id @default(uuid())
  companyId        String       
  reference        String        @db.VarChar(30)
  checkType        QCCheckType
  templateId       String?      
  referenceType    String?       @db.VarChar(60)
  referenceId      String?      
  batchNumber      String?       @db.VarChar(60)
  status           QCStatus      @default(PENDING)
  decision         BatchDecision @default(PENDING)
  inspectorId      String?      
  checkedAt        DateTime?
  approvedById     String?      
  approvedAt       DateTime?
  overallScore     Decimal?      @db.Decimal(5, 2)
  passedParameters Int           @default(0)
  totalParameters  Int           @default(0)
  summary          String?       @db.VarChar(500)
  notes            String?       @db.VarChar(500)
  branchId         String?      
  farmId           String?      
  warehouseId      String?      
  productionSiteId String?      
  createdById      String?      
  updatedById      String?      
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  company           Company                   @relation(fields: [companyId], references: [id])
  template          QualityCheckTemplate?     @relation(fields: [templateId], references: [id])
  inspector         User?                     @relation("QCInspector", fields: [inspectorId], references: [id])
  approvedBy        User?                     @relation("QCApprover", fields: [approvedById], references: [id])
  branch            Branch?                   @relation(fields: [branchId], references: [id])
  results           QualityInspectionResult[]
  labReports        LabReportUpload[]
  rejectedBatch     RejectedBatch?
  approvedBatch     ApprovedBatch?
  correctiveActions CorrectiveAction[]

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([companyId, checkType])
  @@index([companyId, status])
  @@index([companyId, decision])
  @@index([referenceId])
  @@index([deletedAt])
}

model QualityInspectionResult {
  id          String   @id @default(uuid())
  companyId   String  
  checkId     String  
  parameterId String  
  actualValue String?  @db.VarChar(120)
  passed      Boolean  @default(false)
  deviation   Decimal? @db.Decimal(12, 4)
  remarks     String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company               @relation(fields: [companyId], references: [id])
  check     QualityCheck          @relation(fields: [checkId], references: [id])
  parameter QualityCheckParameter @relation(fields: [parameterId], references: [id])

  @@unique([checkId, parameterId])
  @@index([companyId])
  @@index([checkId])
}

model RejectedBatch {
  id              String         @id @default(uuid())
  companyId       String        
  reference       String         @db.VarChar(30)
  checkId         String         @unique
  referenceType   String?        @db.VarChar(60)
  referenceId     String?       
  batchNumber     String?        @db.VarChar(60)
  rejectionReason String         @db.VarChar(500)
  disposalMethod  DisposalMethod @default(QUARANTINE)
  disposalDate    DateTime?
  disposalNotes   String?        @db.VarChar(500)
  quantity        Decimal?       @db.Decimal(15, 4)
  unitOfMeasure   String?        @db.VarChar(20)
  estimatedValue  Decimal?       @db.Decimal(15, 2)
  supplierId      String?       
  createdById     String?       
  updatedById     String?       
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  company           Company           @relation(fields: [companyId], references: [id])
  check             QualityCheck      @relation(fields: [checkId], references: [id])
  supplier          Supplier?         @relation(fields: [supplierId], references: [id])
  correctiveActions CorrectiveAction[]

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([checkId])
  @@index([referenceId])
  @@index([deletedAt])
}

model ApprovedBatch {
  id            String    @id @default(uuid())
  companyId     String   
  reference     String    @db.VarChar(30)
  checkId       String    @unique
  referenceType String?   @db.VarChar(60)
  referenceId   String?  
  batchNumber   String?   @db.VarChar(60)
  stockBatchId  String?  
  quantity      Decimal?  @db.Decimal(15, 4)
  unitOfMeasure String?   @db.VarChar(20)
  approvedById  String?  
  approvalNotes String?   @db.VarChar(500)
  expiryDate    DateTime?
  createdById   String?  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company    Company      @relation(fields: [companyId], references: [id])
  check      QualityCheck @relation(fields: [checkId], references: [id])
  stockBatch StockBatch?  @relation(fields: [stockBatchId], references: [id])
  approvedBy User?        @relation("ApprovedBatchApprover", fields: [approvedById], references: [id])

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([checkId])
  @@index([referenceId])
  @@index([deletedAt])
}

model LabReportUpload {
  id              String    @id @default(uuid())
  companyId       String   
  checkId         String   
  reportNumber    String    @db.VarChar(60)
  labName         String    @db.VarChar(160)
  reportDate      DateTime
  fileUrl         String?   @db.VarChar(500)
  fileType        String?   @db.VarChar(30)
  summary         String?   @db.VarChar(1000)
  findings        String?   @db.VarChar(1000)
  recommendations String?   @db.VarChar(1000)
  uploadedById    String?  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company    Company      @relation(fields: [companyId], references: [id])
  check      QualityCheck @relation(fields: [checkId], references: [id])
  uploadedBy User?        @relation("LabReportUploader", fields: [uploadedById], references: [id])

  @@unique([companyId, reportNumber])
  @@index([companyId])
  @@index([checkId])
  @@index([deletedAt])
}

model CorrectiveAction {
  id                String                 @id @default(uuid())
  companyId         String                
  reference         String                 @db.VarChar(30)
  checkId           String?               
  rejectedBatchId   String?               
  title             String                 @db.VarChar(200)
  description       String                 @db.VarChar(1000)
  rootCause         String?                @db.VarChar(500)
  preventiveMeasure String?                @db.VarChar(500)
  status            CorrectiveActionStatus @default(OPEN)
  priority          String                 @default("MEDIUM") @db.VarChar(20)
  assignedToId      String?               
  dueDate           DateTime?
  completedAt       DateTime?
  verifiedById      String?               
  verifiedAt        DateTime?
  closedAt          DateTime?
  createdById       String?               
  updatedById       String?               
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?

  company       Company        @relation(fields: [companyId], references: [id])
  check         QualityCheck?  @relation(fields: [checkId], references: [id])
  rejectedBatch RejectedBatch? @relation(fields: [rejectedBatchId], references: [id])
  assignedTo    User?          @relation("CorrectiveActionAssignee", fields: [assignedToId], references: [id])
  verifiedBy    User?          @relation("CorrectiveActionVerifier", fields: [verifiedById], references: [id])

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([checkId])
  @@index([rejectedBatchId])
  @@index([companyId, status])
  @@index([deletedAt])
}

model AiChatSession {
  id        String   @id @default(uuid())
  companyId String  
  userId    String  
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id])
  user     User            @relation(fields: [userId], references: [id])
  messages AiChatMessage[]

  @@index([companyId, userId])
  @@index([companyId, createdAt])
}

model AiChatMessage {
  id        String   @id @default(uuid())
  sessionId String  
  role      String
  content   String
  createdAt DateTime @default(now())

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

model AiAlert {
  id                 String           @id @default(uuid())
  companyId          String          
  branchId           String?         
  farmId             String?         
  warehouseId        String?         
  productionSiteId   String?         
  category           AiAlertCategory
  severity           AiAlertSeverity  @default(MEDIUM)
  status             AiAlertStatus    @default(UNREAD)
  title              String
  message            String
  requiredPermission String
  metadata           Json?
  entityType         String?
  entityId           String?
  entityName         String?
  acknowledgedAt     DateTime?
  acknowledgedById   String?         
  resolvedAt         DateTime?
  resolvedById       String?         
  expiresAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  company          Company         @relation(fields: [companyId], references: [id])
  branch           Branch?         @relation(fields: [branchId], references: [id])
  farm             Farm?           @relation(fields: [farmId], references: [id])
  warehouse        Warehouse?      @relation(fields: [warehouseId], references: [id])
  productionSite   ProductionSite? @relation(fields: [productionSiteId], references: [id])
  acknowledgedBy   User?           @relation("AiAlertAcknowledger", fields: [acknowledgedById], references: [id])
  resolvedBy       User?           @relation("AiAlertResolver", fields: [resolvedById], references: [id])

  @@index([companyId, status])
  @@index([companyId, category])
  @@index([companyId, severity])
  @@index([companyId, createdAt])
  @@index([farmId])
  @@index([warehouseId])
  @@index([productionSiteId])
}

model AiForecast {
  id            String   @id @default(uuid())
  companyId     String  
  category      AiAlertCategory
  entityType    String
  entityId      String
  entityName    String
  forecastDate  DateTime
  forecastValue Float
  unit          String?
  confidence    Float    @default(0.7)
  metadata      Json?
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, category])
  @@index([companyId, forecastDate])
  @@index([entityType, entityId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  LOW_STOCK_ALERT
  EXPIRY_ALERT
  VACCINATION_REMINDER
  MEDICATION_REMINDER
  PRODUCTION_ORDER_COMPLETED
  PURCHASE_APPROVAL_NEEDED
  CUSTOMER_PAYMENT_OVERDUE
  SUPPLIER_PAYMENT_DUE
  MACHINE_MAINTENANCE_DUE
  AI_RISK_ALERT
  TASK_ASSIGNED
  QUALITY_BATCH_REJECTED
  STOCK_TRANSFER_REQUEST
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  UNREAD
  READ
}

model Notification {
  id          String             @id @default(uuid())
  companyId   String            
  userId      String            
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(UNREAD)
  title       String
  body        String
  entityType  String?
  entityId    String?           
  metadata    Json?
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId, userId, status])
  @@index([companyId, userId, createdAt])
  @@index([companyId, type])
}

model NotificationPreference {
  id               String              @id @default(uuid())
  userId           String             
  companyId        String             
  notificationType NotificationType
  inApp            Boolean             @default(true)
  email            Boolean             @default(false)
  sms              Boolean             @default(false)
  whatsapp         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, notificationType])
  @@index([userId])
  @@index([companyId])
}

model NotificationConfig {
  id                String   @id @default(uuid())
  companyId         String   @unique
  emailEnabled      Boolean  @default(false)
  emailFromAddress  String?
  emailFromName     String?
  smsEnabled        Boolean  @default(false)
  whatsappEnabled   Boolean  @default(false)
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Mobile Offline Sync ──────────────────────────────────────────────────────

enum MobileSyncStatus {
  SYNCED
  DUPLICATE
  FAILED
}

// ─── QuickBooks Online Integration ───────────────────────────────────────────

enum QBSyncStatus {
  NOT_SYNCED
  PENDING
  SYNCED
  FAILED
}

enum QBEnvironment {
  SANDBOX
  PRODUCTION
}

enum QBMappingType {
  INCOME_ACCOUNT
  EXPENSE_ACCOUNT
  ASSET_ACCOUNT
  BANK_ACCOUNT
  TAX_CODE
  PAYMENT_METHOD
  EXPENSE_CATEGORY
}

enum QBSyncOperation {
  CUSTOMER_SYNC
  VENDOR_SYNC
  ITEM_SYNC
  INVOICE_SYNC
  PAYMENT_SYNC
  BILL_SYNC
  EXPENSE_SYNC
  FULL_SYNC
  MANUAL_SYNC
  WEBHOOK_SYNC
  SCHEDULED_SYNC
}

enum QBSyncResult {
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum QBWebhookStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

model MobileSyncRecord {
  id        String           @id @default(uuid())
  companyId String          
  userId    String          
  localId   String
  module    String
  endpoint  String
  method    String           @default("POST")
  recordId  String?
  status    MobileSyncStatus @default(SYNCED)
  errorMsg  String?
  payload   Json?
  syncedAt  DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, localId])
  @@index([companyId, userId])
  @@index([companyId, syncedAt])
}

// ─── QuickBooks Online Models ─────────────────────────────────────────────────

model QuickBooksConnection {
  id            String        @id @default(uuid())
  companyId     String        @unique
  realmId       String        @db.VarChar(50)
  environment   QBEnvironment @default(SANDBOX)
  connectedAt   DateTime      @default(now())
  connectedById String       
  disconnectedAt DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company      Company                  @relation(fields: [companyId], references: [id])
  connectedBy  User                     @relation("QBConnectedBy", fields: [connectedById], references: [id])
  token        QuickBooksToken?
  syncLogs     QuickBooksSyncLog[]
  webhookEvents QuickBooksWebhookEvent[]
  mappings     QuickBooksMapping[]

  @@index([companyId])
  @@index([realmId])
}

model QuickBooksToken {
  id                    String               @id @default(uuid())
  connectionId          String               @unique
  accessTokenEnc        String               @db.Text
  refreshTokenEnc       String               @db.Text
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  connection QuickBooksConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

model QuickBooksMapping {
  id            String               @id @default(uuid())
  companyId     String              
  connectionId  String              
  mappingType   QBMappingType
  erpEntityId   String?              @db.VarChar(100)
  erpEntityName String               @db.VarChar(200)
  qbEntityId    String               @db.VarChar(100)
  qbEntityName  String               @db.VarChar(200)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company    Company              @relation(fields: [companyId], references: [id])
  connection QuickBooksConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, mappingType, erpEntityId])
  @@index([companyId])
  @@index([connectionId])
  @@index([mappingType])
}

model QuickBooksSyncLog {
  id               String               @id @default(uuid())
  companyId        String              
  connectionId     String              
  operation        QBSyncOperation
  result           QBSyncResult
  entityType       String?              @db.VarChar(50)
  entityId         String?              @db.VarChar(100)
  qbEntityId       String?              @db.VarChar(50)
  recordsProcessed Int                  @default(0)
  recordsSucceeded Int                  @default(0)
  recordsFailed    Int                  @default(0)
  errorMessage     String?              @db.Text
  details          Json?
  triggeredById    String?             
  startedAt        DateTime             @default(now())
  completedAt      DateTime?
  durationMs       Int?
  createdAt        DateTime             @default(now())

  company     Company              @relation(fields: [companyId], references: [id])
  connection  QuickBooksConnection @relation(fields: [connectionId], references: [id])
  triggeredBy User?                @relation("QBSyncTriggeredBy", fields: [triggeredById], references: [id])

  @@index([companyId])
  @@index([connectionId])
  @@index([companyId, operation])
  @@index([companyId, result])
  @@index([startedAt])
}

model QuickBooksWebhookEvent {
  id           String                @id @default(uuid())
  connectionId String?              
  realmId      String                @db.VarChar(50)
  entityType   String                @db.VarChar(50)
  entityId     String                @db.VarChar(50)
  operation    String                @db.VarChar(20)
  eventDate    DateTime
  rawPayload   Json
  status       QBWebhookStatus       @default(PENDING)
  processedAt  DateTime?
  errorMessage String?               @db.Text
  retryCount   Int                   @default(0)
  receivedAt   DateTime              @default(now())
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  connection QuickBooksConnection? @relation(fields: [connectionId], references: [id])

  @@index([connectionId])
  @@index([realmId])
  @@index([status])
  @@index([receivedAt])
}

model LoginRateLimit {
  id        String   @id @default(uuid())
  key       String   @db.VarChar(320)
  attempts  Int      @default(1)
  windowEnd DateTime

  @@index([key])
  @@index([windowEnd])
}

// ── Leave Request System ──────────────────────────────────────────────────────

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  COMPASSIONATE
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id            String      @id @default(uuid())
  companyId     String     
  employeeId    String?    
  employeeName  String      @db.VarChar(160)
  employeeCode  String?     @db.VarChar(30)
  reference     String      @db.VarChar(30)
  leaveType     LeaveType
  startDate     DateTime
  endDate       DateTime
  daysRequested Int
  reason        String?     @db.VarChar(500)
  status        LeaveStatus @default(PENDING)
  reviewedById  String?    
  reviewNote    String?     @db.VarChar(500)
  reviewedAt    DateTime?
  createdById   String?    
  updatedById   String?    
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  company  Company   @relation(fields: [companyId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, employeeId])
  @@index([deletedAt])
}
