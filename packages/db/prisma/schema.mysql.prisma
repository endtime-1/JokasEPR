model Expense {
  id               String        @id @default(uuid())
  companyId        String       
  reference        String        @db.VarChar(30)
  categoryId       String       
  description      String        @db.VarChar(240)
  amount           Decimal       @db.Decimal(15, 2)
  currency         String        @default("GHS") @db.VarChar(10)
  expenseDate      DateTime
  paymentMethod    PaymentMethod
  vendorName       String?       @db.VarChar(160)
  receiptRef       String?       @db.VarChar(120)
  notes            String?       @db.VarChar(500)
  branchId         String?      
  status           ExpenseStatus @default(PENDING)
  approvalRequired Boolean       @default(false)
  submittedById    String       
  approvedById     String?      
  approvedAt       DateTime?
  rejectedById     String?      
  rejectedAt       DateTime?
  rejectionReason  String?       @db.VarChar(240)
