// ─── Finance Module ──────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum ExpenseStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

enum RevenueSource {
  PRODUCT_SALES
  SERVICE_FEES
  RENTAL_INCOME
  INVESTMENT_INCOME
  OTHER
}

enum BankAccountType {
  CURRENT
  SAVINGS
  FIXED_DEPOSIT
  MOBILE_MONEY
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum PettyCashType {
  FUNDING
  DISBURSEMENT
  REPLENISHMENT
}

enum JournalEntryType {
  STANDARD
  OPENING
  CLOSING
  ADJUSTMENT
  REVERSAL
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
  CANCELLED
}

enum BatchType {
  FLOCK
  FEED_PRODUCTION
  SOYA_PROCESSING
}

model Account {
  id          String      @id @default(uuid())
  companyId   String     
  code        String      @db.VarChar(24)
  name        String      @db.VarChar(120)
  type        AccountType
  parentId    String?    
  isActive    Boolean     @default(true)
  description String?     @db.VarChar(240)
  createdById String?    
  updatedById String?    
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  company           Company            @relation(fields: [companyId], references: [id])
  parent            Account?           @relation("AccountParent", fields: [parentId], references: [id])
  children          Account[]          @relation("AccountParent")
  journalLines      JournalEntryLine[]
  expenseCategories ExpenseCategory[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, type])
  @@index([deletedAt])
}

model ExpenseCategory {
