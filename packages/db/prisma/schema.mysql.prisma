  approvedBy  User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  rejectedBy  User?           @relation("ExpenseRejector", fields: [rejectedById], references: [id])
  bankAccount BankAccount?    @relation(fields: [bankAccountId], references: [id])
  branch      Branch?         @relation(fields: [branchId], references: [id])

  @@unique([companyId, reference])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, expenseDate])
  @@index([submittedById])
  @@index([deletedAt])
}

