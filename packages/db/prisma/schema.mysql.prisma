model Farm {
  id          String       @id @default(uuid())
  companyId   String      
  branchId    String      
  name        String
  code        String
  type        FarmType     @default(POULTRY)
  status      RecordStatus @default(ACTIVE)
  location    String?
  createdById String?     
  updatedById String?     
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  company           Company            @relation(fields: [companyId], references: [id])
  branch            Branch             @relation(fields: [branchId], references: [id])
  poultryHouses     PoultryHouse[]
  warehouses        Warehouse[]
  users             User[]
  inventoryItems    InventoryItem[]
  stockBatches      StockBatch[]
  stockMovements    StockMovement[]    @relation("StockMovementFarmContext")
  movementsFromFarm StockMovement[]    @relation("StockMovementFromFarm")
  movementsToFarm   StockMovement[]    @relation("StockMovementToFarm")
  userAccesses      UserFarmAccess[]
  auditLogs         AuditLog[]
  systemSettings    SystemSetting[]
  dashboardMetricSnapshots DashboardMetricSnapshot[]
  dashboardAlerts   DashboardAlert[]
  aiAlerts          AiAlert[]
  flockBatches      FlockBatch[]
  dailyPoultryRecords DailyPoultryRecord[]
  mortalityRecords MortalityRecord[]
  feedConsumptionRecords FeedConsumptionRecord[]
  eggProductionRecords EggProductionRecord[]
  birdWeightRecords BirdWeightRecord[]
  medicationRecords MedicationRecord[]
  vaccinationRecords VaccinationRecord[]
  poultryTransferRecordsFrom PoultryTransferRecord[] @relation("PoultryTransferFromFarm")
  poultryTransferRecordsTo PoultryTransferRecord[] @relation("PoultryTransferToFarm")
  poultryHealthObservations PoultryHealthObservation[]
  poultryCostRecords PoultryCostRecord[]
  pens               Pen[]
  batchPenAllocations BatchPenAllocation[]
  feedInternalTransfersToFarm FeedInternalTransfer[]
  stockReservations StockReservation[]
  machines          Machine[]
  equipment         Equipment[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceRecords MaintenanceRecord[]
  breakdownRecords  BreakdownRecord[]
  machineDowntimeRecords MachineDowntimeRecord[]
  maintenanceCosts  MaintenanceCost[]
  employees         Employee[]
  hrTasks           Task[]
  departmentAssignments DepartmentAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([deletedAt])
}

model ProductionSite {
