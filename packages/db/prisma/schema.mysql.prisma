  deletedAt   DateTime?

  company                    Company                    @relation(fields: [companyId], references: [id])
  branch                     Branch                     @relation(fields: [branchId], references: [id])
  warehouses                 Warehouse[]
  users                      User[]
  inventoryItems             InventoryItem[]
  stockBatches               StockBatch[]
  stockMovements             StockMovement[]           @relation("StockMovementProductionSiteContext")
  movementsFromProductionSite StockMovement[]           @relation("StockMovementFromProductionSite")
  movementsToProductionSite  StockMovement[]            @relation("StockMovementToProductionSite")
  userAccesses               UserProductionSiteAccess[]
  auditLogs                  AuditLog[]
  systemSettings             SystemSetting[]
  dashboardMetricSnapshots   DashboardMetricSnapshot[]
  dashboardAlerts            DashboardAlert[]
  aiAlerts                   AiAlert[]
  feedProductionOrders       FeedProductionOrder[]
  feedProductionBatches      FeedProductionBatch[]
  feedRawMaterialUsages      FeedRawMaterialUsage[]
  feedQualityChecks          FeedQualityCheck[]
  finishedFeedStocks         FinishedFeedStock[]
  feedPackagingRecords       FeedPackagingRecord[]
  feedProductionCosts        FeedProductionCost[]
  soyaBeanIntakes            SoyaBeanIntake[]
  soyaProcessingBatches      SoyaProcessingBatch[]
  soyaOilOutputs             SoyaOilOutput[]
  soyaCakeOutputs            SoyaCakeOutput[]
  soyaWasteRecords           SoyaWasteRecord[]
  soyaQualityChecks          SoyaQualityCheck[]
  soyaProductionCosts        SoyaProductionCost[]
  soyaInternalTransfers      SoyaInternalTransfer[]
  soyaInternalTransfersToSite SoyaInternalTransfer[] @relation("SoyaTransferToProductionSite")
  soyaSalesLinks             SoyaSalesLink[]
  warehouseLocations         WarehouseLocation[]
  stockAdjustments           StockAdjustment[]
  stockTransfersFromSite     StockTransfer[] @relation("StockTransferFromProductionSite")
  stockTransfersToSite       StockTransfer[] @relation("StockTransferToProductionSite")
  stockReorderLevels         StockReorderLevel[]
  stockExpiryAlerts          StockExpiryAlert[]
  inventoryValuations        InventoryValuation[]
  stockReservations          StockReservation[]
  machines                   Machine[]
  equipment                  Equipment[]
  maintenanceSchedules       MaintenanceSchedule[]
  maintenanceRecords         MaintenanceRecord[]
  breakdownRecords           BreakdownRecord[]
  machineDowntimeRecords     MachineDowntimeRecord[]
  maintenanceCosts           MaintenanceCost[]
  employees                  Employee[]
  hrTasks                    Task[]
  departmentAssignments      DepartmentAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
  @@index([companyId, type])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([deletedAt])
