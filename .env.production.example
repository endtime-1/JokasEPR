# ══════════════════════════════════════════════════════════════════════════════
# Jokas ERP — Production Environment Variables (Hostinger + MySQL)
# Copy this to .env on your Hostinger server and fill in every value.
# NEVER commit the filled-in file to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Runtime mode ──────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Database (Hostinger MySQL) ─────────────────────────────────────────────────
# Format: mysql://USERNAME:PASSWORD@localhost:3306/DATABASE_NAME
# Get these from Hostinger → Hosting → MySQL Databases
DATABASE_URL="mysql://u123456789_username:STRONG_DB_PASSWORD@localhost:3306/u123456789_dbname"

# ── JWT secrets — generate with: openssl rand -hex 64 ────────────────────────
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_ACCESS"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_REFRESH"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="30"

# ── API server ────────────────────────────────────────────────────────────────
API_PORT="4001"
API_PREFIX="api"
API_VERSION="1"

# ── CORS — comma-separated list of allowed origins ────────────────────────────
WEB_ORIGIN="https://yourdomain.com"

# ── Frontend URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://yourdomain.com/api/v1"

# ── Mobile app API URL ────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL="https://yourdomain.com/api/v1"

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB="20"
UPLOAD_DIR="/home/username/uploads"

# ── Anthropic AI (Claude) ─────────────────────────────────────────────────────
AI_API_KEY="sk-ant-REPLACE_WITH_REAL_ANTHROPIC_API_KEY"
AI_MODEL="claude-sonnet-4-6"
AI_MODELS="claude-sonnet-4-6,claude-haiku-4-5-20251001"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_ADDRESS="noreply@yourdomain.com"
SMTP_FROM_NAME="Jokas ERP"

# ── SMS / WhatsApp — optional ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_FROM_NUMBER=""

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="warn"
