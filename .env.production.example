# ══════════════════════════════════════════════════════════════════════════════
# Jokas ERP — Production Environment Variables
# Copy this to .env.production and fill in every value before deploying.
# NEVER commit .env.production to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Runtime mode ──────────────────────────────────────────────────────────────
NODE_ENV="production"

# ── Database ──────────────────────────────────────────────────────────────────
# The service name "postgres" resolves inside the Docker network.
# Use your managed DB host (e.g. RDS endpoint) if not self-hosting.
DATABASE_URL="postgresql://jokas_prod:STRONG_DB_PASSWORD@postgres:5432/jokas_erp?schema=public"

# ── PostgreSQL container credentials (must match DATABASE_URL above) ──────────
POSTGRES_USER="jokas_prod"
POSTGRES_PASSWORD="STRONG_DB_PASSWORD"
POSTGRES_DB="jokas_erp"

# ── JWT secrets — generate with: openssl rand -hex 64 ────────────────────────
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_ACCESS"
JWT_REFRESH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_REFRESH"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="30"

# ── API server ────────────────────────────────────────────────────────────────
API_PORT="4001"
API_PREFIX="api"
API_VERSION="1"

# ── CORS — comma-separated list of allowed origins ────────────────────────────
# Must match the exact URL users will access the ERP from (including https://)
WEB_ORIGIN="https://erp.yourdomain.com"

# ── Frontend URL (must use the same domain, nginx routes /api/ to backend) ───
NEXT_PUBLIC_API_URL="https://erp.yourdomain.com/api/v1"

# ── Mobile app API URL (public IP or domain) ──────────────────────────────────
EXPO_PUBLIC_API_URL="https://erp.yourdomain.com/api/v1"

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_MB="20"
# Absolute path inside the API container where uploads are stored
UPLOAD_DIR="/app/uploads"

# ── Anthropic AI (Claude) ─────────────────────────────────────────────────────
AI_API_KEY="sk-ant-REPLACE_WITH_REAL_ANTHROPIC_API_KEY"
AI_MODEL="claude-sonnet-4-6"
AI_MODELS="claude-sonnet-4-6,claude-haiku-4-5-20251001"

# ── Email (SMTP) — optional, for notifications ───────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# ── SMS / WhatsApp — optional ─────────────────────────────────────────────────
TWILIO_SID=""
TWILIO_TOKEN=""
TWILIO_FROM=""

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="warn"

# ── Error monitoring — optional (Sentry, Glitchtip, etc.) ────────────────────
# SENTRY_DSN=""
